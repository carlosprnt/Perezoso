# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used only in server-side admin operations (optional for MVP)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL — used in Supabase OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Gmail subscription detection ────────────────────────────────────────────
#
# GMAIL_MOCK=true
#   Returns built-in mock subscription data instead of calling the Gmail API.
#   Use this in development so you can test the full Gmail import UI
#   without connecting a real Google account.
#
# To use real Gmail (production):
#   1. Supabase dashboard → Auth → Providers → Google → enable "Save User Token"
#   2. Supabase dashboard → Auth → URL Configuration → add to Allowed Redirect URLs:
#        http://localhost:3000/auth/gmail-callback          (development)
#        https://your-domain.com/auth/gmail-callback        (production)
#
GMAIL_MOCK=true
