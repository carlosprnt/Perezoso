{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "development-simulator"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "image": "latest",
        "resourceClass": "m-medium",
        "appExtensions": [
          {
            "targetName": "PerezozoWidgets",
            "bundleIdentifier": "com.perezoso.app.PerezozoWidgets",
            "entitlements": {
              "com.apple.security.application-groups": [
                "group.com.perezoso.app"
              ]
            }
          }
        ]
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "carlosprnt@icloud.com",
        "ascAppId": "6744066889"
      }
    }
  }
}
