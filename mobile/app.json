{
  "expo": {
    "name": "Perezoso",
    "slug": "perezoso",
    "version": "1.0.0",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "perezoso",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F8FA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.perezoso.app"
    },
    "android": {
      "package": "com.perezoso.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F8FA"
      },
      "edgeToEdgeEnabled": true
    },
    "newArchEnabled": false,
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F8FA"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ed0ce73-b35a-49c7-90c7-8737f808e530"
      }
    },
    "owner": "carlosprnt",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7ed0ce73-b35a-49c7-90c7-8737f808e530"
    }
  }
}
